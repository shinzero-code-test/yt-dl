[app]

# App name
title = Video Downloader

# App package name (use reverse domain notation)
package.name = videodownloader

# Package domain
package.domain = com.exapps

# App version
version = 1.0.0

# App orientation
orientation = portrait

# Runtime permission mode
android.permissions = INTERNET,READ_EXTERNAL_STORAGE,WRITE_EXTERNAL_STORAGE,ACCESS_NETWORK_STATE

# Android API level
android.api = 31

# Android minimum API level
android.minapi = 21

# Android accept licenses
android.accept_sdk_license = True

# App requirements (dependencies)
requirements = python3,kivy,yt-dlp,androidstorage4kivy,plyer,Pillow

# App icon
icon.filename = icon.png

# App source files
source.include_exts = py,png,jpg,jpeg,ttf,json

# App exclude files
source.exclude_patterns = __pycache__,*.pyc,*.pyo,.git

# App fullscreen
fullscreen = 0

# Window dimensions
window.width = 480
window.height = 800
window.top = 0
window.left = 0

# App log level
log_level = 2

# App allow debugging
android.debug_port = 0

# Enable Android backup
android.allow_backup = True

# Android Lint
android.lint = []

# P4A (Python for Android) configuration
p4a.hook_dyn_requirements = []

# P4A fullscreen
p4a.fullscreen = False

# P4a弗里 load 
